# Copy this file to .env and fill in your values
# .env is gitignored — never commit credentials

# Your FPL team ID (find it in the URL on the FPL website)
FPL_TEAM_ID=

# Fantasy Football Hub credentials
FFH_EMAIL=
FFH_PASSWORD=

# Optional: your FPL login (for private league data)
FPL_EMAIL=
FPL_PASSWORD=
